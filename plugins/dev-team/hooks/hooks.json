{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/block-nested-delegation.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "(dev-team:)?(setup|product-owner|architect|ui-designer|lead|backend|frontend|dba|qa|qa-frontend|qa-backend|release-manager|infra|cybersec|tech-writer)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/log-activity.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "(dev-team:)?(setup|product-owner|architect|ui-designer|lead|backend|frontend|dba|qa|qa-frontend|qa-backend|release-manager|infra|cybersec|tech-writer)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/log-activity.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
